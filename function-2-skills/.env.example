# function-2-skills — environment contract
# Copy to .env (next to this file) and fill in values your agent runtime
# can read. The skills reference these variables when emitting CRM payloads
# or calling third-party sourcing / enrichment APIs.

# ---- agentic-app CRM (required for Push to CRM) ----
# Base URL of the agentic-app server (the destination for /api/push).
CRM_URL=http://localhost:4210

# Bearer token for write endpoints. Leave empty in local dev when the
# server runs without AGENTIC_APP_TOKEN set. In production, set both
# server-side and here so writes are authenticated.
AGENTIC_APP_TOKEN=

# Provenance source tag prepended to every push from this skill set.
# The skill itself appends ":<skill-name>:v<version>" at runtime.
SKILL_SOURCE_PREFIX=function-2-skills

# ---- Tier 1 sourcing & enrichment (recommended for production) ----
# Apollo.io — firmographic + persona search + contact info
APOLLO_API_KEY=

# Clay — orchestration layer that wraps Apollo, Hunter, Apify, etc.
# When present, lead-sourcing-clay can run multi-source workflows.
CLAY_API_KEY=

# Email verifier (pick one — the skills detect which is set)
MILLION_VERIFIER_API_KEY=
NEVERBOUNCE_API_KEY=
ZEROBOUNCE_API_KEY=

# Hunter.io — domain → email pattern + verifier
HUNTER_API_KEY=

# ---- Tier 2 sourcing (LinkedIn + web) ----
# LinkedIn Sales Navigator does not have a public API. The skills emit
# search filters / Sales Nav URLs and (optionally) ingest CSVs from
# the user or these tools:
APIFY_API_KEY=
PHANTOMBUSTER_API_KEY=
HEYREACH_API_KEY=

# Web search / news / job boards — for lead-sourcing-web triggers
SERPAPI_KEY=
GOOGLE_CSE_API_KEY=
GOOGLE_CSE_CX=

# ---- Tier 3 (optional, alternate firmographic sources) ----
ZOOMINFO_API_KEY=
LUSHA_API_KEY=
COGNISM_API_KEY=

# ---- Carry-overs from function-1-skills (already used upstream) ----
# Not required at function-2 runtime, but referenced when sourcing skills
# enrich a lead with funding / tech-stack signals.
CRUNCHBASE_API_KEY=
BUILTWITH_API_KEY=
G2_API_KEY=

# ---- Existing-CRM-as-source (optional) ----
# When set, sourcing skills can pull warm contacts (former champions,
# closed-lost re-engagement candidates) from the user's primary CRM.
HUBSPOT_API_KEY=
SALESFORCE_API_KEY=

# ---- Cost guardrails ----
# Hard cap (USD) any single sourcing run is allowed to spend without
# explicit confirmation. Skills must quote-before-pull and abort if
# the estimated spend exceeds this without user override.
SOURCING_RUN_USD_CAP=25

# Hard cap on candidate count per pull. Skills page through results but
# refuse to materialize more than this in a single run.
SOURCING_RUN_RECORD_CAP=2000
