# function-6-skills — environment contract
# Reporting & Optimization: A/B test design, ICP refinement loop, channel performance,
# weekly KPI reports, customer feedback analysis. Reads function-3/4/5 data; writes
# back analytical artifacts to CRM.

CRM_URL=http://localhost:4210
AGENTIC_APP_TOKEN=
SKILL_SOURCE_PREFIX=function-6-skills

# ---- LLM for analysis (theme extraction, qualitative coding) ----
ANTHROPIC_API_KEY=
OPENAI_API_KEY=

# ---- Analytics / dashboard delivery ----
SLACK_WEBHOOK_URL=
LINEAR_API_KEY=                              # for routing product feedback to backlog
NOTION_API_KEY=
GOOGLE_SHEETS_API_KEY=

# ---- Customer feedback sources ----
G2_API_KEY=                                  # also used by function-1 competitor-analysis
PRODUCT_REVIEW_RSS_URLS=                     # comma-separated; G2/Capterra/TrustRadius feeds
CHURN_SURVEY_API_KEY=                        # if user has a tool (Pendo, GainSight, etc.)
GAINSIGHT_API_KEY=
PENDO_API_KEY=

# ---- A/B test thresholds ----
AB_TEST_BAYESIAN_THRESHOLD=0.85              # P(B>A) > 0.85 for winner call (n<200/arm)
AB_TEST_FREQUENTIST_P=0.05                   # p<0.05 for winner call (n>=200/arm)
AB_TEST_MIN_EFFECT_SIZE_PP=1.0               # absolute pp; ship only if effect ≥ this

# ---- ICP refinement loop ----
ICP_REFINEMENT_MIN_CLOSED_DEALS=30           # don't refine ICP with <30 closes
ICP_REFINEMENT_AUDIT_QUARTERLY=true

# ---- Reporting cadence ----
KPI_REPORT_CADENCE=weekly                    # weekly | biweekly | monthly
KPI_REPORT_DELIVERY_DAY=monday
KPI_REPORT_TZ=America/Los_Angeles
