# function-4-skills — environment contract
# Conversation Management: classify replies, handle objections, prep discovery calls,
# manage follow-ups. Reads function-3 reply data; writes back to CRM.

CRM_URL=http://localhost:4210
AGENTIC_APP_TOKEN=
SKILL_SOURCE_PREFIX=function-4-skills

# ---- Reply classification (LLM-backed) ----
# When an LLM is the classifier, point at the user's chosen provider.
# Skills MUST attach confidence per classification; <0.75 confidence routes to manual review.
ANTHROPIC_API_KEY=
OPENAI_API_KEY=

# ---- Calendar / scheduling (for follow-up + discovery prep) ----
CALENDLY_API_KEY=
CAL_COM_API_KEY=
GOOGLE_CALENDAR_OAUTH_TOKEN=

# ---- Conversation transcript sources (for discovery-call-prep + downstream) ----
GONG_API_KEY=
CHORUS_API_KEY=
GRAIN_API_KEY=
FATHOM_API_KEY=

# ---- Caps + thresholds ----
REPLY_CLASSIFICATION_CONFIDENCE_FLOOR=0.75   # below: route to manual review
DISCOVERY_BRIEFING_FRESHNESS_DAYS=2          # re-prep if briefing >2 days old
FOLLOW_UP_NURTURE_DEFAULT_DAYS=30            # default 30/60/90 nurture cadence
