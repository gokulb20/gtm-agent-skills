# function-5-skills — environment contract
# Pipeline & Deal Management: stages, hygiene, forecasting, handoff, conversation intel.
# Reads function-3/4 outreach + reply data; writes deal records back to CRM.

CRM_URL=http://localhost:4210
AGENTIC_APP_TOKEN=
SKILL_SOURCE_PREFIX=function-5-skills

# ---- External CRM mirrors (when user runs HubSpot/Salesforce/Pipedrive in parallel) ----
HUBSPOT_API_KEY=
SALESFORCE_API_KEY=
PIPEDRIVE_API_KEY=

# ---- Conversation intelligence sources ----
GONG_API_KEY=
CHORUS_API_KEY=
GRAIN_API_KEY=
FATHOM_API_KEY=

# ---- Calendar (for handoff scheduling + meeting-stage triggers) ----
CALENDLY_API_KEY=
GOOGLE_CALENDAR_OAUTH_TOKEN=

# ---- Pipeline + forecasting defaults ----
DEAL_STAGE_DEFINITIONS=new,contacted,engaged,meeting,discovery,proposal,closed-won,closed-lost
STAGE_CONVERSION_RATE_DEFAULTS=                                # JSON or CSV; user-overridable per stage
FORECAST_HORIZON_DAYS=90
FORECAST_SCENARIOS=conservative,base,aggressive
HANDOFF_FRESHNESS_HOURS=24                                     # re-prep handoff if briefing >24h old
CRM_HYGIENE_REQUIRED_FIELDS_PER_STAGE=                         # JSON; per-stage required-field map
