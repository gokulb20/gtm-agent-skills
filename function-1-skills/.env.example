# function-1-skills — environment contract
# Copy to .env (next to this file) and fill in values your agent runtime
# can read. The skills reference these variables when emitting CRM payloads
# or calling third-party research APIs.

# ---- agentic-app CRM (required for Push to CRM) ----
# Base URL of the agentic-app server (the destination for /api/push).
CRM_URL=http://localhost:4210

# Bearer token for write endpoints. Leave empty in local dev when the
# server runs without AGENTIC_APP_TOKEN set. In production, set both
# server-side and here so writes are authenticated.
AGENTIC_APP_TOKEN=

# Provenance source tag prepended to every push from this skill set.
# The skill itself appends ":<skill-name>:v<version>" at runtime.
SKILL_SOURCE_PREFIX=function-1-skills

# ---- Optional research APIs (referenced in Tools and Sources tables) ----
# Used by skills only when the agent has explicit permission to spend
# on paid databases. Skills must degrade gracefully when these are unset.

# Apollo.io — firmographic + contact enrichment
APOLLO_API_KEY=

# Crunchbase — funding events, company stage
CRUNCHBASE_API_KEY=

# BuiltWith / Wappalyzer — tech stack detection
BUILTWITH_API_KEY=

# G2 — review-site signals
G2_API_KEY=

# LinkedIn Sales Navigator — handled via session-based scraping tools
# (Phantombuster, HeyReach, etc.); not a direct API key.

# ---- Optional alerting / monitoring (used by competitive-intelligence) ----
VISUALPING_API_KEY=
KLUE_API_KEY=
CRAYON_API_KEY=
