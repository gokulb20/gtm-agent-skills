# function-3-skills — environment contract
# Copy to .env (next to this file) and fill in values your agent runtime
# can read. The skills reference these variables when emitting CRM payloads
# or calling outreach tools (sending platforms, LinkedIn automation, dialers).

# ---- agentic-app CRM (required for Push to CRM) ----
CRM_URL=http://localhost:4210
AGENTIC_APP_TOKEN=
SKILL_SOURCE_PREFIX=function-3-skills

# ---- Email sending platforms (Tier 1) ----
# Pick whichever the user has; skills detect which is set.
SMARTLEAD_API_KEY=
INSTANTLY_API_KEY=
LEMLIST_API_KEY=

# ---- Email sending platforms (Tier 2 — enterprise) ----
OUTREACH_API_KEY=
SALESLOFT_API_KEY=
APOLLO_SEQUENCES_API_KEY=

# ---- Email infrastructure & deliverability ----
# DNS / domain verification
GODADDY_API_KEY=
CLOUDFLARE_API_KEY=
NAMECHEAP_API_KEY=

# Email warm-up
WARMUP_INBOX_API_KEY=
MAILFLOW_API_KEY=
SMARTLEAD_WARMUP_API_KEY=    # uses SMARTLEAD_API_KEY if set above

# DMARC / DKIM / SPF auditing
MXTOOLBOX_API_KEY=
EASYDMARC_API_KEY=

# Sender reputation monitoring (read-only — feeds campaign-management)
GOOGLE_POSTMASTER_OAUTH_TOKEN=
MICROSOFT_SNDS_API_KEY=
TALOSINTEL_API_KEY=

# ---- LinkedIn outreach tools ----
# These use the user's own LinkedIn session — never direct scraping.
HEYREACH_API_KEY=
DRIPIFY_API_KEY=
LEMLIST_LI_API_KEY=         # uses LEMLIST_API_KEY if set above
MEETALFRED_API_KEY=
PHANTOMBUSTER_API_KEY=       # also used by lead-sourcing-linkedin

# ---- Cold-calling / dialer tools ----
JUSTCALL_API_KEY=
AIRCALL_API_KEY=
ORUM_API_KEY=
DIALPAD_API_KEY=
CONNECTANDSELL_API_KEY=

# ---- DNC scrubbing (mandatory before US calling) ----
DNC_COM_API_KEY=
CONTACTCENTERCOMPLIANCE_API_KEY=

# ---- Capacity caps (sending hygiene — non-negotiable) ----
# These cap *touches sent*, not dollars spent. Skills must surface every
# cap hit and never bypass silently.

# Email: cold-outbound from a single domain
SENDS_PER_DOMAIN_PER_DAY_CAP=30          # safe; absolute ceiling 50
SENDS_PER_MAILBOX_PER_DAY_CAP=30         # per individual mailbox
WARMED_UP_DAYS_THRESHOLD=14              # min domain age before cold sends
WARMUP_SCORE_THRESHOLD=70                # min score (0-100) before cold sends

# LinkedIn: weekly limits (LI's soft cap is ~100; we stay below)
LINKEDIN_CONNECTS_PER_WEEK_CAP=80
LINKEDIN_MESSAGES_PER_WEEK_CAP=200       # to existing connections
LINKEDIN_INMAIL_PER_MONTH_CAP=50         # depends on Sales Nav seat

# Cold calling: per rep per day
CALLS_PER_REP_PER_DAY_CAP=80             # warn above 100; productive ceiling
VOICEMAILS_PER_REP_PER_DAY_CAP=40

# Campaign-level
CAMPAIGN_TOTAL_RECIPIENTS_CAP=500        # force tier-segmentation above this
CAMPAIGN_DAILY_VOLUME_CAP=200            # max touches/day across channels

# ---- Reputation thresholds (campaign-management gates active sends on these) ----
BOUNCE_RATE_PAUSE_THRESHOLD=0.05         # 5% — pause campaign immediately
BOUNCE_RATE_WARN_THRESHOLD=0.02          # 2% — warn user, slow down
COMPLAINT_RATE_PAUSE_THRESHOLD=0.003     # 0.3% — Google/MS hard limit
COMPLAINT_RATE_WARN_THRESHOLD=0.001      # 0.1% — Google/MS target
REPLY_RATE_FLOOR=0.03                    # 3% — below this = bad targeting/copy
